async function getStock(symbol){

try{

const res=await fetch(`/api/stock?symbol=${symbol}`)
const data=await res.json()

return data

}catch{

return null

}

}

async function refreshPortfolio(){

let total=0
let prev=0

for(const stock of portfolio){

const data=await getStock(stock.symbol)

if(!data||!data.current)continue

stock.current=data.current
stock.prev=data.previousClose||data.current

total+=stock.current*stock.shares
prev+=stock.prev*stock.shares

}

const profit=total-prev

document.getElementById("totalValue").innerText="£"+total.toFixed(2)
document.getElementById("profitValue").innerText="£"+profit.toFixed(2)
document.getElementById("positionCount").innerText=portfolio.length
document.getElementById("lastUpdated").innerText=new Date().toLocaleTimeString()

history.push(total)
if(history.length>30)history.shift()

performanceChart.data.labels=history.map((_,i)=>i)
performanceChart.data.datasets[0].data=history
performanceChart.update()

pieChart.data.labels=portfolio.map(s=>s.symbol)
pieChart.data.datasets[0].data=portfolio.map(s=>s.current*s.shares)
pieChart.update()

}

async function loadNews(){

const res=await fetch("/api/news")
const news=await res.json()

const container=document.getElementById("newsContainer")

container.innerHTML=""

news.slice(0,6).forEach(n=>{

container.innerHTML+=`
<div class="bg-slate-700 p-2 rounded mb-2">
<a href="${n.url}" target="_blank">${n.headline}</a>
</div>
`

})

}

loadNews()
setInterval(refreshPortfolio,15000)
